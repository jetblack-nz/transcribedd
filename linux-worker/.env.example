# Required
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-jwt>

# Unique name for this worker — stored in jobs.worker_id
WORKER_ID=debian-gpu-worker-01

# Whisper — large-v3 + int8 fits in ~1.5 GB VRAM (safe for T600 with other workloads)
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=5

# Per-stage timeouts in seconds
TIMEOUT_DOWNLOAD=300
TIMEOUT_CONVERT=1800
TIMEOUT_TRANSCRIBE=14400
TIMEOUT_UPLOAD=120

# Polling fallback interval (seconds) when Realtime is idle
POLL_INTERVAL_SECONDS=30

# debug | info | warning | error
LOG_LEVEL=info
